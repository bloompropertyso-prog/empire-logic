# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only (Vercel env var, NOT prefixed with VITE_)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Stripe ───────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...
STRIPE_SECRET_KEY=sk_live_or_sk_test_...

# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Your Stripe Price IDs (Stripe Dashboard → Products → your plan → Prices)
STRIPE_PRICE_FOUNDER=price_...
STRIPE_PRICE_EMPIRE=price_...

# ── App ──────────────────────────────────────────────────────
# Your production URL (used in Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
